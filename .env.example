# ─── Database ─────────────────────────────────────────────
# Opsi 1: Gunakan DATABASE_URL langsung (URL lengkap dari Supabase, misal postgresql://postgres.id:pass@aws-0-xyz.pooler.supabase.com:6543/postgres)
# DATABASE_URL=postgresql://xxxx

# Opsi 2: Atau gunakan variabel terpisah (untuk lokal/docker biasanya)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=calorie_tracker
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Groq API ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── USDA API ─────────────────────────────────────────────
USDA_API_KEY=your_usda_api_key_here

# ─── App ──────────────────────────────────────────────────
APP_ENV=development
FUZZY_THRESHOLD=80
