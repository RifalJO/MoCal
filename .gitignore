# pyenv
#   For a library or binary, you wish to ignore these files during development
#   For a project, you're expected to check these in
# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not check in Pipfile.lock into version control.
#   But each master of their own fate.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   This is especially true for applications, but for libraries it is less clear.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# pdm.lock
#   pdm maintains its own version of .python-version
.pdm-python

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

